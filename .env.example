# ============================================================
# .env.example — TEMPLATE production-ready
#
# Per dev locale: `cp .env.example .env` e tienilo con i valori
# di sviluppo qui sotto. `.env` non va MAI committato (vedi
# .gitignore).
#
# Per produzione: NON copiare il file su Portainer. Apri questo
# elenco a fianco e incolla manualmente UNA VARIABILE ALLA VOLTA
# nella UI dello stack Portainer (Stack → Environment variables).
# Sostituisci ogni "<...>" con il valore reale generato secondo
# le istruzioni nei commenti.
# ============================================================


# ------------------------------------------------------------
# Ambiente: dev | prod
# ------------------------------------------------------------
# - dev: SECRET_KEY/ADMIN_* hanno fallback se mancano (warning a log)
# - prod: SECRET_KEY, ADMIN_EMAIL, ADMIN_PASSWORD obbligatorie:
#         se manca anche solo una, l'app NON parte.
ENV=prod


# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
# Chiave segreta usata per firmare i token. In prod genera con:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# Ruotala se sospetti che sia stata vista da qualcuno: invalida
# tutti i token attivi (gli utenti rifaranno login una volta).
SECRET_KEY=<generate-with-secrets.token_urlsafe-48>

# Durata del token JWT in minuti (default 30).
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ------------------------------------------------------------
# Bootstrap del primo admin
# ------------------------------------------------------------
# Al primo avvio, se la tabella `users` e' vuota, l'app crea
# automaticamente un account admin con queste credenziali. Dal
# secondo avvio in poi non viene piu' toccato nulla: cambia la
# password al primo login, le successive non vengono sovrascritte.
#
# Scegli un'email reale (per recovery) e una password forte
# (almeno 16 caratteri, mix maiuscole/minuscole/numeri/simboli):
#     python -c "import secrets; print(secrets.token_urlsafe(20))"
ADMIN_EMAIL=<your-admin-email>
ADMIN_PASSWORD=<strong-random-password>


# ------------------------------------------------------------
# Database PostgreSQL
# ------------------------------------------------------------
# Le 4 variabili qui sotto vengono usate da Postgres alla prima
# inizializzazione del volume e dal backend per connettersi.
# DATABASE_URL deve essere coerente con loro (host = "db" perche'
# e' il nome del servizio nel docker-compose).
POSTGRES_USER=<choose-a-username>
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=<choose-a-db-name>
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db/<POSTGRES_DB>


# ------------------------------------------------------------
# CORS — origini autorizzate
# ------------------------------------------------------------
# Lista di domini da cui il browser puo' parlare col backend,
# separati da virgola, NIENTE spazi, NIENTE wildcard "*"
# (incompatibile con allow_credentials=True).
#
# In prod: il dominio reale del sito.
# In dev: "http://localhost:5173,http://127.0.0.1:5173"
CORS_ORIGINS=https://your-prod-domain.example.org


# ------------------------------------------------------------
# URL pubblico del sito — usato nei link delle mail transazionali
# ------------------------------------------------------------
# Es. "https://hub.parametricomparison.unimore.it". NIENTE slash finale.
# Le mail di welcome / reset password generano link tipo
# `${SITE_URL}/reset-password?token=...`, quindi questo deve essere il
# dominio che l'utente raggiunge dal browser (non l'host interno docker).
# In dev tipicamente "http://localhost:5173". Se non impostato in prod
# l'app non parte (stessa filosofia di SECRET_KEY).
SITE_URL=https://your-prod-domain.example.org


# ------------------------------------------------------------
# SMTP — invio mail transazionali (reset password, welcome, ...)
# ------------------------------------------------------------
# Configurazione del server SMTP che il backend usa per spedire mail.
# In dev sono OPZIONALI: se manca SMTP_HOST il backend non invia nulla
# e il servizio email logga "SMTP non configurato, skip" (utile per
# evitare di mandare mail di test reali mentre sviluppi).
# In prod sono OBBLIGATORIE: l'app si rifiuta di partire se manca anche
# solo una delle quattro variabili (SMTP_FROM puo' coincidere con SMTP_USER).
#
# Esempio caso "Google Workspace UniMoRe" (mailbox @unimore.it gestita
# su Gmail tramite App Password generata dalla sezione Sicurezza):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=noreply.pcm@unimore.it
#   SMTP_PASSWORD=<app-password-16-caratteri-senza-spazi>
#   SMTP_FROM=noreply.pcm@unimore.it
#
# Nota: con Gmail SMTP, il From DEVE coincidere con l'account autenticato
# (SMTP_USER), altrimenti Google riscrive il mittente o rifiuta la mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<smtp-username>
SMTP_PASSWORD=<smtp-password-or-app-password>
SMTP_FROM=<from-address>
