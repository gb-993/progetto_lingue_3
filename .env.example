# ============================================================
# .env.example — copia in `.env` e personalizza i valori
# Il file `.env` reale NON va committato (vedi .gitignore)
# ============================================================

# dev | prod
# - dev: SECRET_KEY ha un fallback se manca (warning)
# - prod: SECRET_KEY obbligatoria, l'app non parte se assente
ENV=dev

# Chiave per firmare i JWT. In prod genera con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Ruotala se compromessa (invalida tutti i token attivi).
SECRET_KEY=change-me-in-production

# Durata token JWT in minuti
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- Database Postgres ----
POSTGRES_USER=pcm_user
POSTGRES_PASSWORD=pcm_password
POSTGRES_DB=pcm_hub
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completo (deve essere coerente con i 5 valori sopra).
# In docker compose: host = "db" (nome del servizio).
# In sviluppo fuori container: host = "localhost".
DATABASE_URL=postgresql://pcm_user:pcm_password@db/pcm_hub

# ---- CORS ----
# Lista di origini autorizzate, separate da virgola.
# Includi sia gli host di sviluppo che quelli di produzione.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
