.idea/
.vscode/
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
logs/

# ---- Documentazione: solo i PDF vanno in repo ----
# Le sorgenti markdown e gli screenshot del manuale stanno solo in locale, così
# si possono modificare/rigenerare senza appesantire la repo (e la VM tira solo
# i PDF dalla repo, non serve nient'altro).
docs/*.md
docs/img/
