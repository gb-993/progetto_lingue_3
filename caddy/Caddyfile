# Caddyfile — reverse proxy + HTTPS automatico per PCM-Hub.
#
# Caddy si occupa di:
#   - tirare giu un certificato Let's Encrypt al primo avvio e rinnovarlo
#     automaticamente ogni 60 giorni (richiede porte 80 e 443 aperte da
#     internet e DNS del dominio puntato all'IP della VM);
#   - servire la SPA da /srv/dist (volume nominato `frontend_dist`,
#     popolato dal service `frontend_build` allo start dello stack);
#   - fare reverse-proxy verso il backend FastAPI per /api/* e /auth/*;
#   - gzip/zstd e header proxy standard.
#
# Quando arrivera' il certificato dei servizi informatici, sostituire il
# blocco "tls" con il path ai file .crt/.key (vedi commenti sotto).

{
	# Email per notifiche di scadenza certificato Let's Encrypt.
	# Sostituiscila con un'email che leggi davvero.
	email gbmatteazzi93@gmail.com
}

hub.parametricomparison.unimore.it {
	# HTTPS automatico Let's Encrypt (default Caddy: nessuna config esplicita).
	# Quando avrai il certificato dei servizi informatici, COMMENTA il blocco
	# automatico (cancellare la sezione "email" sopra non serve, e' innocua)
	# e DECOMMENTA il blocco tls qui sotto:
	#
	# tls /etc/caddy/certs/server.crt /etc/caddy/certs/server.key

	encode gzip zstd

	# Limite dimensione body: il bundle di migrazione e' max 200 MB lato app,
	# qui blocchiamo prima a 250 MB per non sprecare banda.
	request_body {
		max_size 250MB
	}

	# Backend FastAPI per le route API, auth e health check.
	# X-Forwarded-* sono aggiunti automaticamente da reverse_proxy.
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /auth/* {
		reverse_proxy backend:8000
	}
	handle /healthz {
		reverse_proxy backend:8000
	}

	# PDF dei documenti legali (ToU, Privacy Notice) caricati dall'admin via UI.
	# Il backend li scrive nel volume `legal_archive` (vedi compose), montato
	# qui in /srv/legal_documents (read-only). I file sono per natura pubblici
	# (un contratto e' conoscibile da chi lo sottoscrive), quindi nessuna auth.
	handle_path /legal-docs/* {
		root * /srv/legal_documents
		file_server
	}

	# Tutto il resto: SPA React. try_files con fallback a index.html
	# permette il deep-linking (/parameters/SPK, ecc.) senza 404.
	handle {
		root * /srv/dist
		try_files {path} /index.html
		file_server
	}

	# Pagina di manutenzione PCM-style per errori 5xx: scatta quando il
	# backend non e' raggiungibile (502 da reverse_proxy) o restituisce
	# un 500/503/504. Il file e' in /srv/dist/maintenance.html (committato
	# in frontend/dist/ via build) cosi' Caddy puo' servirlo anche se il
	# backend e' completamente giu'. Retry-After: 60s e' un suggerimento
	# standard per i client (browser, monitor) di riprovare a breve.
	handle_errors {
		@5xx expression `{err.status_code} >= 500 && {err.status_code} < 600`
		handle @5xx {
			root * /srv/dist
			rewrite * /maintenance.html
			header Retry-After "60"
			file_server
		}
	}

	# Header di sicurezza.
	#
	# Documentazione delle scelte (utile per il prossimo che mette mano qui):
	#
	# - HSTS: dice al browser "questo sito va sempre in HTTPS, anche se l'utente
	#   digita http://". max-age=1 anno (valore standard). includeSubDomains
	#   propaga la regola ai sottodomini del dominio servito. NON aggiungiamo
	#   `preload`: e' quasi irreversibile (va inviato a hstspreload.org e poi i
	#   browser lo ricordano per anni anche se rimosso). Aggiungilo solo dopo
	#   essere certi che TUTTI i sottodomini supporteranno per sempre HTTPS.
	#
	# - CSP (Content-Security-Policy): elenca cosa il browser puo' caricare ed
	#   eseguire. Mitiga XSS: anche se un attaccante riesce a iniettare HTML,
	#   il browser rifiuta di caricare script o connettersi a domini non in
	#   lista. Trade-off attuali:
	#     * 'unsafe-inline' su script: necessario per lo script di bootstrap
	#       del tema in index.html. In futuro si puo' migrare a nonce o a un
	#       file esterno con hash sha256-... e rimuovere 'unsafe-inline'.
	#     * 'unsafe-inline' su style: necessario perche' React usa molti
	#       `style={{...}}` inline in Layout/PublicHome/ecc. Rimuoverlo
	#       richiederebbe estrarre tutti gli inline style in CSS classes.
	#     * img-src include *.openstreetmap.org (tile della mappa pubblica)
	#       e licensebuttons.net (badge CC nel footer).
	#     * connect-src 'self' basta perche' tutte le chiamate XHR/fetch
	#       vanno al backend stesso dominio via Caddy.
	#     * frame-ancestors 'none' equivale a X-Frame-Options DENY (sotto)
	#       ma e' lo standard moderno; teniamo entrambi per browser vecchi.
	#
	# - Permissions-Policy: nega esplicitamente API browser che NON usiamo
	#   (geolocation, microfono, camera, ...). Se un domani un componente
	#   le richiede, vanno tolte dalla blocklist.
	header {
		# Forza HTTPS per 1 anno + sottodomini.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"

		# Whitelist di cosa il browser puo' caricare/eseguire.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.openstreetmap.org https://*.tile.openstreetmap.org https://licensebuttons.net; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"

		# Disabilita API browser che non usiamo (microfono, camera, GPS, ...).
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

		# Niente sniffing del Content-Type
		X-Content-Type-Options nosniff
		# Anti-clickjacking (compat browser vecchi; equivalente di frame-ancestors 'none')
		X-Frame-Options DENY
		# Referrer policy moderata
		Referrer-Policy strict-origin-when-cross-origin
		# Rimuovi header che rivela lo stack
		-Server
	}

	log {
		output stdout
		format console
	}
}
